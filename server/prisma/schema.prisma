// Prisma schema updated from database.docx
// MongoDB version — compatible with Prisma Client JS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ----------------------
// User model
// ----------------------
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String   @unique
  username    String?
  email       String   @unique
  first_name  String?
  last_name   String?
  role        String   @default("user")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  projects    Project[]        @relation("UserProjects")
  editHistory EditHistory[]    @relation("UserEditHistory")
  exports     Export[]         @relation("UserExports")

  @@map("users")
}

// ----------------------
// Project model
// ----------------------
model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  user     User?     @relation("UserProjects", fields: [clerk_id], references: [clerk_id])
  pages    Page[]    @relation("ProjectPages")
  exports  Export[]  @relation("ProjectExports")

  @@map("projects")
}

// ----------------------
// Page model
// ----------------------
model Page {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  name           String
  json_structure Json
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  project       Project?       @relation("ProjectPages", fields: [project_id], references: [id])
  components    Component[]    @relation("PageComponents")
  editHistories EditHistory[]  @relation("PageEditHistories")

  @@map("pages")
}

// ----------------------
// Component model
// ----------------------
model Component {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id       String?  @db.ObjectId
  theme         String?
  type          String
  properties    Json
  order_index   Int?
  parent_id     String?  @db.ObjectId
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relation
  page          Page?    @relation("PageComponents", fields: [page_id], references: [id])

  @@map("components")
}

// ----------------------
// Edit History model
// ----------------------
model EditHistory {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id            String   @db.ObjectId
  clerk_id           String
  action             String   // ADD, UPDATE, DELETE, DUPLICATE, MOVE
  component_snapshot Json
  created_at         DateTime @default(now())

  // Relations
  user  User?  @relation("UserEditHistory", fields: [clerk_id], references: [clerk_id])
  page  Page?  @relation("PageEditHistories", fields: [page_id], references: [id])

  @@map("edit_history")
}

// ----------------------
// Export model
// ----------------------
model Export {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  clerk_id       String
  json_snapshot  Json
  bundle_path    String
  created_at     DateTime @default(now())

  // Relations
  user    User?    @relation("UserExports", fields: [clerk_id], references: [clerk_id])
  project Project? @relation("ProjectExports", fields: [project_id], references: [id])

  @@map("exports")
}
