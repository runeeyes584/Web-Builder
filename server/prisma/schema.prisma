// Prisma schema updated from database.docx
// MongoDB version — compatible with Prisma Client JS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String   @unique
  username    String?
  email       String   @unique
  first_name  String?
  last_name   String?
  role        String   @default("user")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  projects    Project[]
  editHistory EditHistory[]
  exports     Export[]

  @@map("users")
}

// Project model
model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String   // FK → User.clerk_id
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  pages   Page[]
  exports Export[]

  @@map("projects")
}

// Page model
model Page {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  name           String
  json_structure Json
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  components    Component[]
  editHistories EditHistory[]

  @@map("pages")
}

// Component model
model Component {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id       String?  @db.ObjectId
  theme         String?
  type          String   // Text, Image, Video, Button, Input, Container, Row, Column
  properties    Json
  order_index   Int?
  parent_id     String?  @db.ObjectId
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("components")
}

// Edit History model
model EditHistory {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id            String   @db.ObjectId
  clerk_id           String   // FK → User.clerk_id
  action             String   // ADD, UPDATE, DELETE, DUPLICATE, MOVE
  component_snapshot Json
  created_at         DateTime @default(now())

  @@map("edit_history")
}

// Export model
model Export {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  clerk_id       String   // FK → User.clerk_id
  json_snapshot  Json
  bundle_path    String
  created_at     DateTime @default(now())

  @@map("exports")
}
