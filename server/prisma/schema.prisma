// Prisma schema updated from database.docx
// MongoDB version — compatible with Prisma Client JS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ----------------------
// User model
// ----------------------
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String   @unique
  username    String?
  email       String   @unique
  first_name  String?
  last_name   String?
  role        String   @default("user")
  is_deleted  Boolean  @default(false)
  deleted_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  projects    Project[]        @relation("UserProjects")
  editHistory EditHistory[]    @relation("UserEditHistory")
  exports     Export[]         @relation("UserExports")

  @@map("users")
}

// ----------------------
// Project model
// ----------------------
model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerk_id    String
  name        String
  description String?
  is_public   Boolean  @default(false)  // Public projects can be viewed by anyone
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  user            User?              @relation("UserProjects", fields: [clerk_id], references: [clerk_id])
  pages           Page[]             @relation("ProjectPages")
  exports         Export[]           @relation("ProjectExports")
  collaborators   ProjectCollaborator[] @relation("ProjectCollaborators")
  invitations     ProjectInvitation[]   @relation("ProjectInvitations")

  @@map("projects")
}

// ----------------------
// Project Collaborator model
// ----------------------
model ProjectCollaborator {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id  String   @db.ObjectId
  clerk_id    String   // User being granted access
  role        String   @default("editor") // owner, editor, viewer
  added_by    String   // clerk_id of the person who added this collaborator
  added_at    DateTime @default(now())
  last_active DateTime @default(now())

  // Relations
  project     Project  @relation("ProjectCollaborators", fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, clerk_id])
  @@map("project_collaborators")
}

// ----------------------
// Project Invitation model
// ----------------------
model ProjectInvitation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id  String   @db.ObjectId
  email       String   // Email of invitee
  role        String   @default("editor")
  invited_by  String   // clerk_id
  token       String   @unique
  status      String   @default("pending") // pending, accepted, rejected, expired
  expires_at  DateTime
  created_at  DateTime @default(now())

  // Relations
  project     Project  @relation("ProjectInvitations", fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_invitations")
}

// ----------------------
// Active Session model (for real-time presence)
// ----------------------
model ActiveSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id  String   @db.ObjectId
  clerk_id    String
  username    String
  color       String   // Cursor color for this user
  last_seen   DateTime @default(now())
  cursor_pos  Json?    // {x, y, elementId}
  
  @@unique([project_id, clerk_id])
  @@map("active_sessions")
}

// ----------------------
// Page model
// ----------------------
model Page {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  name           String
  json_structure Json
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  project       Project?       @relation("ProjectPages", fields: [project_id], references: [id])
  components    Component[]    @relation("PageComponents")
  editHistories EditHistory[]  @relation("PageEditHistories")

  @@map("pages")
}

// ----------------------
// Component model
// ----------------------
model Component {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id       String?  @db.ObjectId
  theme         String?
  type          String
  properties    Json
  order_index   Int?
  parent_id     String?  @db.ObjectId
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relation
  page          Page?    @relation("PageComponents", fields: [page_id], references: [id])

  @@map("components")
}

// ----------------------
// Edit History model
// ----------------------
model EditHistory {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  page_id            String   @db.ObjectId
  clerk_id           String
  action             String   // ADD, UPDATE, DELETE, DUPLICATE, MOVE
  component_snapshot Json
  created_at         DateTime @default(now())

  // Relations
  user  User?  @relation("UserEditHistory", fields: [clerk_id], references: [clerk_id])
  page  Page?  @relation("PageEditHistories", fields: [page_id], references: [id])

  @@map("edit_history")
}

// ----------------------
// Export model
// ----------------------
model Export {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  project_id     String   @db.ObjectId
  clerk_id       String
  json_snapshot  Json
  bundle_path    String
  created_at     DateTime @default(now())

  // Relations
  user    User?    @relation("UserExports", fields: [clerk_id], references: [clerk_id])
  project Project? @relation("ProjectExports", fields: [project_id], references: [id])

  @@map("exports")
}
